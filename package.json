{
  "name": "astro-pigment",
  "version": "0.11.2",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "keywords": [
    "astro",
    "astro-integration",
    "docs",
    "documentation",
    "theme"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/psd-coder/astro-pigment"
  },
  "files": [
    "src",
    "stylelint.config.js",
    ".browserslistrc",
    "README.md"
  ],
  "scripts": {
    "bump": "bash scripts/bump.sh",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run --recursive --filter='.' /^lint:*/",
    "lint:oxlint": "oxlint .",
    "lint:prettier": "prettier --check . --experimental-cli",
    "format": "pnpm run --recursive --filter='.' /^format:*/",
    "format:oxlint": "oxlint --fix --fix-suggestions .",
    "format:prettier": "prettier . --write --experimental-cli"
  },
  "exports": {
    ".": "./src/index.ts",
    "./content": "./src/content.ts",
    "./components": "./src/components/index.ts",
    "./components/playground": "./src/components/playground.ts",
    "./stores/media": "./src/stores/media.ts",
    "./stores/pkgManager": "./src/stores/pkgManager.ts",
    "./stores/theme": "./src/stores/theme.ts",
    "./loaders/examples": "./src/loaders/examples.ts",
    "./utils/content": "./src/utils/content.ts",
    "./utils/cssModules": "./src/utils/cssModules.ts",
    "./utils/defineCodePanels": "./src/utils/defineCodePanels.ts",
    "./utils/dom": "./src/utils/dom.ts",
    "./utils/fonts": "./src/utils/fonts.ts",
    "./utils/github": "./src/utils/github.ts",
    "./utils/icon": "./src/utils/icon.ts",
    "./utils/markdown": "./src/utils/markdown.ts",
    "./utils/nanostores": "./src/utils/nanostores.ts",
    "./utils/response": "./src/utils/response.ts",
    "./utils/schemas": "./src/utils/schemas.ts",
    "./utils/urls": "./src/utils/urls.ts",
    "./styles/*": "./src/styles/*",
    "./types": "./src/types.ts",
    "./stylelint.config": "./stylelint.config.js",
    "./browserslist": "./.browserslistrc"
  },
  "peerDependencies": {
    "astro": "^6.0.0",
    "nanostores": "^1.0.0",
    "nanotags": "^0.14.0",
    "sharp": "^0.34.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/sitemap": "^3.7.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.3",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.0",
    "@lezer/highlight": "^1.2.3",
    "@nanostores/persistent": "^1.3.0",
    "codemirror": "^6.0.1",
    "es-module-lexer": "^2.0.0",
    "es-toolkit": "^1.45.1",
    "fuse.js": "7.4.0-beta.1",
    "github-slugger": "^2.0.0",
    "keyux": "^0.11.3",
    "linkedom": "^0.18.12",
    "mdast-util-to-string": "^4.0.0",
    "nanoid": "^5.1.7",
    "postcss-preset-env": "^11.0.0",
    "rehype-autolink-headings": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "typed-channel": "^0.10.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@prettier/plugin-oxc": "^0.1.4",
    "@types/mdast": "^4.0.4",
    "astro": "^6.1.5",
    "nanostores": "^1.0.0",
    "nanotags": "^0.15.0",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  }
}
