{
  "name": "@psd-coder/astro-docs-theme",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --fix --fix-suggestions",
    "format": "oxfmt --write src/"
  },
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./components/playground": "./src/components/playground.ts",
    "./components/playground/CodePanels": "./src/components/CodePanels/index.ts",
    "./stores/theme": "./src/stores/theme.ts",
    "./stores/media": "./src/stores/media.ts",
    "./stores/pkgManager": "./src/stores/pkgManager.ts",
    "./loaders/examples": "./src/loaders/examples-loader.ts",
    "./utils/*": "./src/utils/*.ts",
    "./styles/*": "./src/styles/*",
    "./types": "./src/types.ts",
    "./stylelint.config": "./stylelint.config.js",
    "./browserslist": "./.browserslistrc"
  },
  "peerDependencies": {
    "astro": "^6.0.0",
    "nanotags": "^0.14.0",
    "nanostores": "^1.0.0"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.1",
    "@catppuccin/codemirror": "^1.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.0",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.3",
    "@codemirror/lang-json": "^6.0.1",
    "@nanostores/persistent": "^1.3.0",
    "codemirror": "^6.0.1",
    "es-toolkit": "^1.45.1",
    "linkedom": "^0.18.12",
    "nanoid": "^5.1.7",
    "postcss-preset-env": "^11.0.0",
    "sharp": "^0.34.0",
    "rehype-autolink-headings": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "astro": "^6.0.8",
    "nanotags": "^0.14.0",
    "nanostores": "^1.0.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3"
  }
