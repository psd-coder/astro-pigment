---
import { Icon } from "../Icon";
import styles from "./styles.module.css";
---
<template id="copy-code-btn">
  <button class={styles.copyBtn} type="button" aria-label="Copy code">
    <span data-icon="copy"><Icon name="copy" size={16} /></span>
    <span data-icon="check" hidden><Icon name="check" size={16} /></span>
  </button>
</template>
<script>
  function initCopyButtons() {
    const tpl = document.getElementById("copy-code-btn") as HTMLTemplateElement | null;
    if (!tpl) return;

    document.querySelectorAll<HTMLPreElement>(".prose pre").forEach((pre) => {
      if (pre.parentElement?.hasAttribute("data-code-block")) return;

      const wrapper = document.createElement("div");
      wrapper.setAttribute("data-code-block", "");
      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const btn = tpl.content.firstElementChild!.cloneNode(true) as HTMLButtonElement;
      btn.setAttribute("data-copy-btn", "");
      wrapper.appendChild(btn);

      btn.addEventListener("click", async () => {
        const text = pre.querySelector("code")?.textContent ?? pre.textContent ?? "";
        await navigator.clipboard.writeText(text);
        const iconCopy = btn.querySelector<HTMLElement>("[data-icon=copy]")!;
        const iconCheck = btn.querySelector<HTMLElement>("[data-icon=check]")!;
        iconCopy.hidden = true;
        iconCheck.hidden = false;
        setTimeout(() => {
          iconCopy.hidden = false;
          iconCheck.hidden = true;
        }, 1500);
      });
    });
  }

  document.addEventListener("astro:page-load", initCopyButtons);
</script>
