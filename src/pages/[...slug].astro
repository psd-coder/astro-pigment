---
import { render } from "astro:content";
import { tocItemsSelector } from "virtual:theme-integration-config";
import Layout from "../components/Layout/Layout.astro";
import PageHeading from "../components/PageHeading/PageHeading.astro";
import PrevNextNav from "../components/PrevNextNav/PrevNextNav.astro";
import TableOfContents from "../components/TableOfContents/TableOfContents.astro";
import { getDocsStaticPaths } from "../utils/content";
import { getHref } from "../utils/urls";

export const getStaticPaths = getDocsStaticPaths;

const { doc, prev, next } = Astro.props;
const { Content, headings } = await render(doc);
---

<Layout title={doc.data.title} description={doc.data.description}>
  <TableOfContents
    slot="sidebar"
    headings={headings}
    itemsSelector={tocItemsSelector}
  />
  <article class="prose">
    <PageHeading title={doc.data.title} href={getHref(`${doc.id}.md`)} />
    <Content />
    <PrevNextNav prev={prev} next={next} />
  </article>
</Layout>
