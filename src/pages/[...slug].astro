---
import { render } from "astro:content";
import Layout from "../components/Layout/Layout.astro";
import PageHeading from "../components/PageHeading/PageHeading.astro";
import PrevNextNav from "../components/PrevNextNav/PrevNextNav.astro";
import TableOfContents from "../components/TableOfContents/TableOfContents.astro";
import { getDocsStaticPaths } from "../utils/content";
import { getMarkdownAlternate } from "../utils/urls";

export const getStaticPaths = getDocsStaticPaths;

const { doc, prev, next } = Astro.props;
const { Content, headings } = await render(doc);
const mdAlternate = doc.body ? getMarkdownAlternate(doc.id) : undefined;
---

<Layout
  title={doc.data.title}
  description={doc.data.description}
  alternate={mdAlternate && [mdAlternate]}
>
  <TableOfContents slot="sidebar" headings={headings} />
  <article id="content" class="prose">
    <PageHeading title={doc.data.title} href={mdAlternate?.href} />
    <Content />
    <PrevNextNav prev={prev} next={next} />
  </article>
</Layout>
